<!-- Expose ClickHouse's internal metrics in Prometheus format on :9363.
     Mounted into /etc/clickhouse-server/config.d/ by compose.olap.yml. -->
<clickhouse>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>
</clickhouse>
